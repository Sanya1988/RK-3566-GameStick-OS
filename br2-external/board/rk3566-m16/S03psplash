#!/bin/sh

asset_dir="/usr/share/gamestick/boot"

show_image() {
	image_path=$1
	console_device="/dev/tty1"

	[ -f "$image_path" ] || return 1
	command -v fbv >/dev/null 2>&1 || return 1

	if [ ! -c "$console_device" ]; then
		console_device="/dev/console"
	fi
	[ -c "$console_device" ] || return 1

	fbv -c -u -i -f -s 1 "$image_path" <"$console_device" >"$console_device" 2>&1
}

case "$1" in
	start)
		if show_image "$asset_dir/boot-splash.png"; then
			:
		elif command -v psplash >/dev/null 2>&1; then
			pidof psplash >/dev/null 2>&1 || /usr/bin/psplash -n >/dev/null 2>&1 &
		fi
		;;
esac
