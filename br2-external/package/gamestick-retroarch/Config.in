config BR2_PACKAGE_GAMESTICK_RETROARCH
	bool "gamestick-retroarch"
	depends on BR2_TOOLCHAIN_USES_GLIBC
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on !BR2_STATIC_LIBS
	depends on BR2_aarch64 || BR2_arm
	select BR2_PACKAGE_ALSA_LIB
	select BR2_PACKAGE_FREETYPE
	select BR2_PACKAGE_GAMESTICK_BIOS
	select BR2_PACKAGE_GAMESTICK_INPUT
	select BR2_PACKAGE_GAMESTICK_LIBRETRO_CORES_R1
	select BR2_PACKAGE_GAMESTICK_LIBUDEV_ZERO
	select BR2_PACKAGE_GAMESTICK_MALI_R25P0_WAYLAND_RUNTIME
	select BR2_PACKAGE_GAMESTICK_RETROARCH_ASSETS
	select BR2_PACKAGE_ROCKCHIP_MALI
	select BR2_PACKAGE_ZLIB
	help
	  RetroArch frontend configured for RK3566 console use through
	  KMS/EGL/OpenGLES with ALSA audio.

comment "gamestick-retroarch needs a glibc toolchain with C++, threads and shared libs"
	depends on !(BR2_TOOLCHAIN_USES_GLIBC && BR2_INSTALL_LIBSTDCPP && BR2_TOOLCHAIN_HAS_THREADS) || BR2_STATIC_LIBS
