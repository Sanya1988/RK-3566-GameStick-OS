#!/bin/sh
set -eu

PATH=/sbin:/bin:/usr/sbin:/usr/bin

STATE_DIR=/run/gamestick-input
PIDFILE="$STATE_DIR/monitor.pid"
SEED_DIR=/usr/share/gamestick/input/retroarch-autoconfig/udev
INDEX_FILE=/usr/share/gamestick/input/autoconfig-index.tsv
TARGET_DIR=/storage/retroarch/autoconfig/udev
USER_PROFILE_DIR=/storage/system/input/profiles/udev
OVERRIDE_DIR=/storage/system/input/overrides/udev
LOG_FILE=/storage/system/logs/input.log

timestamp() {
	date '+%Y-%m-%d %H:%M:%S'
}

log_line() {
	mkdir -p "$(dirname "$LOG_FILE")"
	printf '%s gamestick-input: %s\n' "$(timestamp)" "$*" >>"$LOG_FILE"
}

storage_ready() {
	grep -qs ' /storage ' /proc/mounts
}

normalize_name() {
	printf '%s' "$1" | tr '\t' ' ' | tr -s ' ' | sed 's/^ //; s/ $//'
}

sanitize_name() {
	normalize_name "$1" | sed 's#[/\\]#_#g; s/[^[:alnum:][:space:]._()+-]/_/g; s/^[. ]*//; s/[. ]*$//'
}

profile_filename() {
	name="$(sanitize_name "$1")"
	vendor="${2:-}"
	product="${3:-}"

	[ -n "$name" ] || name="controller"

	if [ -n "$vendor" ] && [ -n "$product" ]; then
		printf '%s__%s_%s.cfg' "$name" "$vendor" "$product"
	else
		printf '%s.cfg' "$name"
	fi
}

ensure_dirs() {
	mkdir -p \
		"$STATE_DIR" \
		"$TARGET_DIR" \
		"$USER_PROFILE_DIR" \
		"$OVERRIDE_DIR" \
		/storage/system/input/profiles \
		/storage/system/input/quirks \
		/storage/system/logs
}

sync_seed_profiles() {
	[ -d "$SEED_DIR" ] || return 0

	find "$SEED_DIR" -maxdepth 1 -type f -name '*.cfg' | while IFS= read -r src; do
		base="$(basename "$src")"
		dst="$TARGET_DIR/$base"
		[ -f "$dst" ] || cp -f "$src" "$dst"
	done
}

sync_user_profiles() {
	[ -d "$USER_PROFILE_DIR" ] || return 0

	find "$USER_PROFILE_DIR" -maxdepth 1 -type f -name '*.cfg' | while IFS= read -r src; do
		base="$(basename "$src")"
		cp -f "$src" "$TARGET_DIR/$base"
		log_line "user profile installed file=\"$base\""
	done
}

apply_user_overrides() {
	[ -d "$OVERRIDE_DIR" ] || return 0

	find "$OVERRIDE_DIR" -maxdepth 1 -type f -name '*.cfg' | while IFS= read -r src; do
		base="$(basename "$src")"
		cp -f "$src" "$TARGET_DIR/$base"
		log_line "override applied file=\"$base\""
	done
}

escape_cfg_value() {
	printf '%s' "$1" | sed 's/[&|\\]/\\&/g; s/"/\\"/g'
}

decimal_from_hex() {
	value="$(printf '%s' "$1" | tr 'A-F' 'a-f')"
	[ -n "$value" ] || return 1
	printf '%d' "0x$value" 2>/dev/null
}

set_cfg_value() {
	cfg_file=$1
	key=$2
	value=$3

	if grep -q "^${key} = " "$cfg_file"; then
		sed -i "s|^${key} = .*|${key} = ${value}|" "$cfg_file"
	else
		printf '%s = %s\n' "$key" "$value" >>"$cfg_file"
	fi
}

delete_cfg_key() {
	cfg_file=$1
	key=$2
	sed -i "/^${key} = /d" "$cfg_file"
}

clear_hotkey_bindings() {
	cfg_file=$1

	delete_cfg_key "$cfg_file" input_enable_hotkey_btn
	delete_cfg_key "$cfg_file" input_enable_hotkey_axis
	delete_cfg_key "$cfg_file" input_enable_hotkey_key
	delete_cfg_key "$cfg_file" input_exit_emulator_btn
	delete_cfg_key "$cfg_file" input_exit_emulator_axis
	delete_cfg_key "$cfg_file" input_exit_emulator_key
	delete_cfg_key "$cfg_file" input_load_state_btn
	delete_cfg_key "$cfg_file" input_load_state_axis
	delete_cfg_key "$cfg_file" input_load_state_key
	delete_cfg_key "$cfg_file" input_menu_toggle_btn
	delete_cfg_key "$cfg_file" input_menu_toggle_axis
	delete_cfg_key "$cfg_file" input_menu_toggle_key
	delete_cfg_key "$cfg_file" input_save_state_btn
	delete_cfg_key "$cfg_file" input_save_state_axis
	delete_cfg_key "$cfg_file" input_save_state_key
}

hotkey_binding_value() {
	input_type=$1
	input_id=$2
	input_value=${3:-1}

	case "$input_type" in
		button|key)
			printf '"%s"' "$input_id"
			;;
		axis)
			if [ "$input_value" = "-1" ]; then
				printf '"-%s"' "$input_id"
			else
				printf '"+%s"' "$input_id"
			fi
			;;
		*)
			return 1
			;;
	esac
}

hotkey_binding_key_suffix() {
	case "$1" in
		button)
			echo btn
			;;
		axis|key)
			echo "$1"
			;;
		*)
			return 1
			;;
	esac
}

extract_esde_hotkeys() {
	input_xml=/storage/esde/settings/es_input.xml
	[ -f "$input_xml" ] || return 0

	awk '
		function attr(line, key,    pattern, start, value) {
			pattern = key "=\""
			start = index(line, pattern)
			if (!start)
				return ""
			value = substr(line, start + length(pattern))
			sub(/".*/, "", value)
			return value
		}
		/<inputConfig / {
			device_name = attr($0, "deviceName")
			hotkey_type = ""
			hotkey_id = ""
			hotkey_value = ""
			start_type = ""
			start_id = ""
			start_value = ""
			select_type = ""
			select_id = ""
			select_value = ""
			load_type = ""
			load_id = ""
			load_value = ""
			save_type = ""
			save_id = ""
			save_value = ""
			next
		}
		/<input name="hotkey"/ || /<input name="hotkeyenable"/ {
			hotkey_type = attr($0, "type")
			hotkey_id = attr($0, "id")
			hotkey_value = attr($0, "value")
			next
		}
		/<input name="start"/ {
			start_type = attr($0, "type")
			start_id = attr($0, "id")
			start_value = attr($0, "value")
			next
		}
		/<input name="select"/ {
			select_type = attr($0, "type")
			select_id = attr($0, "id")
			select_value = attr($0, "value")
			next
		}
		/<input name="pageup"/ {
			load_type = attr($0, "type")
			load_id = attr($0, "id")
			load_value = attr($0, "value")
			next
		}
		/<input name="pagedown"/ {
			save_type = attr($0, "type")
			save_id = attr($0, "id")
			save_value = attr($0, "value")
			next
		}
		/<\/inputConfig>/ {
			if (device_name != "")
				printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n", \
					device_name, \
					hotkey_type, hotkey_id, hotkey_value, \
					start_type, start_id, start_value, \
					select_type, select_id, select_value, \
					load_type, load_id, load_value, \
					save_type, save_id, save_value
			device_name = ""
			hotkey_type = ""
			hotkey_id = ""
			hotkey_value = ""
			start_type = ""
			start_id = ""
			start_value = ""
			select_type = ""
			select_id = ""
			select_value = ""
			load_type = ""
			load_id = ""
			load_value = ""
			save_type = ""
			save_id = ""
			save_value = ""
		}
	' "$input_xml"
}

sync_cfg_binding() {
	cfg_file=$1
	prefix=$2
	input_type=$3
	input_id=$4
	input_value=${5:-1}

	if binding_value="$(hotkey_binding_value "$input_type" "$input_id" "$input_value" 2>/dev/null)" && \
		binding_key_suffix="$(hotkey_binding_key_suffix "$input_type" 2>/dev/null)"; then
		set_cfg_value "$cfg_file" "${prefix}_${binding_key_suffix}" "$binding_value"
		return 0
	fi

	return 1
}

sync_esde_hotkeys() {
	[ -d "$TARGET_DIR" ] || return 0

	extract_esde_hotkeys | while IFS="$(printf '\t')" read -r \
		device_name \
		hotkey_type hotkey_id hotkey_value \
		start_type start_id start_value \
		select_type select_id select_value \
		load_type load_id load_value \
		save_type save_id save_value; do
		[ -n "$device_name" ] || continue

		find "$TARGET_DIR" -maxdepth 1 -type f -name '*.cfg' | while IFS= read -r cfg_file; do
			grep -Fq "input_device = \"$device_name\"" "$cfg_file" || continue

			clear_hotkey_bindings "$cfg_file"

			if binding_value="$(hotkey_binding_value "$hotkey_type" "$hotkey_id" "$hotkey_value" 2>/dev/null)" && \
				binding_key_suffix="$(hotkey_binding_key_suffix "$hotkey_type" 2>/dev/null)"; then
				set_cfg_value "$cfg_file" "input_enable_hotkey_${binding_key_suffix}" "$binding_value"
				sync_cfg_binding "$cfg_file" input_menu_toggle "$select_type" "$select_id" "$select_value" || true
				sync_cfg_binding "$cfg_file" input_exit_emulator "$start_type" "$start_id" "$start_value" || true
				sync_cfg_binding "$cfg_file" input_load_state "$load_type" "$load_id" "$load_value" || true
				sync_cfg_binding "$cfg_file" input_save_state "$save_type" "$save_id" "$save_value" || true
				log_line "esde hotkey synced device=\"$device_name\" file=\"$(basename "$cfg_file")\" type=\"$hotkey_type\" id=\"$hotkey_id\" value=\"$hotkey_value\""
			else
				log_line "esde hotkey cleared device=\"$device_name\" file=\"$(basename "$cfg_file")\""
			fi
		done
	done
}

template_for_device() {
	name="$(normalize_name "$1")"
	vendor=$(printf '%s' "$2" | tr 'A-F' 'a-f')
	product=$(printf '%s' "$3" | tr 'A-F' 'a-f')

	awk -F '\t' -v want_name="$name" -v want_vendor="$vendor" -v want_product="$product" '
		BEGIN {
			exact = ""
			by_name = ""
			by_vidpid = ""
		}
		NR == 1 { next }
		{
			file = $1
			vendor = tolower($3)
			product = tolower($4)
			name = $5
			lookup = $6
			if (lookup == "")
				lookup = name
			if (lookup == want_name && vendor == want_vendor && product == want_product) {
				exact = file
				print exact
				exit
			}
			if (by_name == "" && lookup == want_name)
				by_name = file
			if (by_vidpid == "" && want_vendor != "" && want_product != "" &&
			    vendor == want_vendor && product == want_product)
				by_vidpid = file
		}
		END {
			if (exact != "")
				exit
			if (by_name != "") {
				print by_name
				exit
			}
			if (by_vidpid != "")
				print by_vidpid
		}
	' "$INDEX_FILE" | head -n 1
}

write_alias_profile() {
	template=$1
	name=$2
	vendor=$3
	product=$4
	dst=$5
	escaped_name="$(escape_cfg_value "$name")"

	cp -f "$SEED_DIR/$template" "$dst"

	set_cfg_value "$dst" input_device "\"$escaped_name\""

	if vendor_dec="$(decimal_from_hex "$vendor" 2>/dev/null)"; then
		set_cfg_value "$dst" input_vendor_id "\"$vendor_dec\""
	else
		delete_cfg_key "$dst" input_vendor_id
	fi

	if product_dec="$(decimal_from_hex "$product" 2>/dev/null)"; then
		set_cfg_value "$dst" input_product_id "\"$product_dec\""
	else
		delete_cfg_key "$dst" input_product_id
	fi
}

collect_devices() {
	for js in /sys/class/input/js*; do
		[ -e "$js" ] || continue
		devdir="$(readlink -f "$js/device" 2>/dev/null || true)"
		[ -n "$devdir" ] || continue
		[ -d "$devdir" ] || continue

		name="$(cat "$devdir/name" 2>/dev/null || true)"
		vendor="$(tr 'A-F' 'a-f' < "$devdir/id/vendor" 2>/dev/null || true)"
		product="$(tr 'A-F' 'a-f' < "$devdir/id/product" 2>/dev/null || true)"
		phys="$(cat "$devdir/phys" 2>/dev/null || true)"
		uniq="$(cat "$devdir/uniq" 2>/dev/null || true)"

		[ -n "$name" ] || continue

		printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
			"$(basename "$js")" \
			"$vendor" \
			"$product" \
			"$name" \
			"$phys" \
			"$uniq"
	done
}

refresh_once() {
	[ -f "$INDEX_FILE" ] || return 0
	storage_ready || return 0

	ensure_dirs
	sync_seed_profiles
	sync_user_profiles
	apply_user_overrides
	sync_esde_hotkeys

	tmp_snapshot="$(mktemp "$STATE_DIR/devices.XXXXXX")"

	collect_devices | while IFS="$(printf '\t')" read -r node vendor product name phys uniq; do
		printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
			"$node" "$vendor" "$product" "$name" "$phys" "$uniq" >>"$tmp_snapshot"

		file="$(profile_filename "$name" "$vendor" "$product")"
		dst="$TARGET_DIR/$file"

		if [ -f "$dst" ]; then
			log_line "device=\"$node\" name=\"$name\" vendor=\"$vendor\" product=\"$product\" profile=\"exact\" file=\"$file\""
			continue
		fi

		template="$(template_for_device "$name" "$vendor" "$product" || true)"
		if [ -n "$template" ] && [ -f "$SEED_DIR/$template" ]; then
			write_alias_profile "$template" "$name" "$vendor" "$product" "$dst"
			log_line "device=\"$node\" name=\"$name\" vendor=\"$vendor\" product=\"$product\" profile=\"generated\" template=\"$template\" file=\"$file\""
		else
			log_line "device=\"$node\" name=\"$name\" vendor=\"$vendor\" product=\"$product\" profile=\"unmatched\""
		fi
	done

	mv "$tmp_snapshot" "$STATE_DIR/devices.snapshot"
}

monitor_loop() {
	prev=""
	while :; do
		if storage_ready; then
			sig="$(collect_devices | cksum | awk '{print $1 ":" $2}')"
			if [ "$sig" != "$prev" ]; then
				refresh_once || true
				prev="$sig"
			fi
		fi
		sleep 2
	done
}

case "${1:---once}" in
	--once)
		refresh_once
		;;
	--monitor)
		monitor_loop
		;;
	--stop-monitor)
		if [ -f "$PIDFILE" ]; then
			kill "$(cat "$PIDFILE")" >/dev/null 2>&1 || true
			rm -f "$PIDFILE"
		fi
		;;
	*)
		echo "Usage: $0 [--once|--monitor|--stop-monitor]" >&2
		exit 1
		;;
esac
