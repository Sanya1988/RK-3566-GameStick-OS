config BR2_PACKAGE_GAMESTICK_GAMES_STORAGE
	bool "gamestick-games-storage"
	select BR2_PACKAGE_EXFAT
	select BR2_PACKAGE_EXFATPROGS
	select BR2_PACKAGE_NTFS_3G
	select BR2_PACKAGE_UTIL_LINUX
	select BR2_PACKAGE_UTIL_LINUX_BINARIES
	help
	  Mount the userdata partition labeled USERDATA at /storage during boot,
	  preferring exFAT and keeping NTFS compatibility for older cards,
	  and prepare persistent directories for ROMs and frontend data.
