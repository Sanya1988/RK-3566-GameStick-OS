config BR2_PACKAGE_GAMESTICK_MALI_G52
	bool "gamestick-mali-g52"
	depends on BR2_aarch64
	select BR2_PACKAGE_LIBDRM
	select BR2_PACKAGE_LIBGLVND
	select BR2_PACKAGE_WAYLAND
	select BR2_PACKAGE_HAS_LIBEGL
	select BR2_PACKAGE_HAS_LIBGLES
	select BR2_PACKAGE_HAS_LIBGBM
	select BR2_PACKAGE_LIBGBM_HAS_FEATURE_DMA_BUF
	select BR2_PACKAGE_LIBGBM_HAS_FEATURE_FORMAT_MODIFIER_PLANE_COUNT
	help
	  Install the proprietary Mali G52 userspace stack used as the
	  current compatibility target for GameStick M16 runtime bring-up.

if BR2_PACKAGE_GAMESTICK_MALI_G52

config BR2_PACKAGE_PROVIDES_LIBEGL
	default "gamestick-mali-g52"

config BR2_PACKAGE_PROVIDES_LIBGLES
	default "gamestick-mali-g52"

config BR2_PACKAGE_PROVIDES_LIBGBM
	default "gamestick-mali-g52"

endif

comment "gamestick-mali-g52 needs aarch64"
	depends on !BR2_aarch64
